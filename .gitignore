# deps
node_modules/
.pnpm-store/

# builds
dist/
build/
.svelte-kit/
packages/ui/build/
apps/desktop/src-tauri/target/

# tauri-generated ACL/capability schemas (regenerated on every build)
apps/desktop/src-tauri/gen/schemas/

# sidecar binaries — not vendored. The engine is rebuilt via `pnpm engine:build`;
# the reddb `red-<triple>` binary is copied from red-ui (or built from reddb).
apps/desktop/src-tauri/binaries/*
!apps/desktop/src-tauri/binaries/.gitkeep

# local data / collections written at runtime
.data/
*.local

# os
.DS_Store
Thumbs.db

# logs
*.log
npm-debug.log*

# env
.env
.env.*
!.env.example
