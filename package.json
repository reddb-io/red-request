{
  "name": "red-request",
  "version": "0.63.4",
  "private": true,
  "type": "module",
  "description": "Open-source, white-label API client (Bruno/Insomnia alternative) powered by recker, shipped as a Tauri 2 desktop app.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @reddb-io/request-ui dev",
    "desktop:dev": "pnpm brand:sync && pnpm --filter @reddb-io/request-core build && pnpm --filter @reddb-io/request-engine build && pnpm --filter @reddb-io/request-desktop tauri dev",
    "desktop:build": "pnpm brand:sync && pnpm brand:icons && pnpm --filter @reddb-io/request-core build && pnpm engine:build && pnpm --filter @reddb-io/request-desktop tauri build",
    "engine:build": "node scripts/build-engine.mjs",
    "reddb:preflight": "node scripts/check-reddb-release-assets.mjs x86_64-unknown-linux-gnu x86_64-pc-windows-msvc",
    "reddb:sync": "node scripts/sync-reddb.mjs",
    "reddb:fetch": "node scripts/fetch-reddb.mjs",
    "reddb:migration-demo": "node scripts/reddb-migration-demo.mjs",
    "brand:sync": "node scripts/sync-brand.mjs",
    "brand:icons": "node scripts/brand-icons.mjs",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "perf:build": "node scripts/perf-build.mjs",
    "format": "prettier --write .",
    "changeset": "changeset",
    "release:version": "changeset version && node scripts/sync-desktop-version.mjs",
    "release:publish": "pnpm -r build && changeset publish",
    "prepare": "lefthook install",
    "rr:run": "node packages/cli/dist/cli.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
