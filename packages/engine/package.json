{
  "name": "@red-request/engine",
  "version": "0.1.1",
  "type": "module",
  "private": true,
  "description": "recker sidecar — NDJSON-RPC over stdio, dispatches requests for red-request.",
  "license": "MIT",
  "main": "./dist/main.js",
  "bin": {
    "red-request-engine": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@red-request/core": "workspace:*",
    "recker": "1.0.103"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  }
}
