{
  "name": "@reddb-io/request-engine",
  "version": "0.45.22",
  "type": "module",
  "private": true,
  "description": "recker sidecar — NDJSON-RPC over stdio, dispatches requests for red-request.",
  "license": "MIT",
  "main": "./dist/main.js",
  "bin": {
    "red-request-engine": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.8.1",
    "@reddb-io/request-core": "workspace:*",
    "https-proxy-agent": "^9.1.0",
    "recker": "1.0.103",
    "socks": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "ws": "^8.21.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  }
}
