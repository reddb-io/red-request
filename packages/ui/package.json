{
  "name": "@reddb-io/request-ui",
  "version": "0.63.8",
  "private": true,
  "type": "module",
  "description": "red-request UI — SvelteKit (static) client surface.",
  "scripts": {
    "dev": "vite dev --port 1420 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "svelte-kit sync && vitest run --config vitest.config.ts && vitest run --config vitest.components.config.ts",
    "test:unit": "svelte-kit sync && vitest run --config vitest.config.ts",
    "test:components": "svelte-kit sync && vitest run --config vitest.components.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@fontsource-variable/fira-code": "^5.2.7",
    "@reddb-io/ui": "0.3.1",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-http": "^2.5.9",
    "bits-ui": "^2.18.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.24.0",
    "@reddb-io/request-core": "workspace:*",
    "@sveltejs/adapter-static": "latest",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "clsx": "^2.1.1",
    "jsdom": "^29.1.1",
    "shadcn-svelte": "^1.4.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
