{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Red Request",
  "version": "0.61.5",
  "identifier": "io.reddb.request",
  "build": {
    "beforeDevCommand": "pnpm --filter @reddb-io/request-ui dev",
    "beforeBuildCommand": "pnpm --filter @reddb-io/request-ui build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../../packages/ui/build"
  },
  "app": {
    "windows": [
      {
        "title": "Red Request",
        "width": 1320,
        "height": 860,
        "minWidth": 940,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/red-request-engine",
      "binaries/red"
    ],
    "resources": [
      "resources/*.gz"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Open-source API client, powered by recker.",
    "longDescription": "Open-source, white-label API client (Bruno/Insomnia alternative) that dispatches requests through recker."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "redrequest"
        ]
      }
    }
  }
}
