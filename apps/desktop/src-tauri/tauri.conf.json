{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Red Requester",
  "version": "0.1.0",
  "identifier": "io.reddb.requester",
  "build": {
    "beforeDevCommand": "pnpm --filter @red-requester/ui dev",
    "beforeBuildCommand": "pnpm --filter @red-requester/ui build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../../packages/ui/build"
  },
  "app": {
    "windows": [
      {
        "title": "Red Requester",
        "width": 1320,
        "height": 860,
        "minWidth": 940,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/red-requester-engine"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Open-source API client, powered by recker.",
    "longDescription": "Open-source, white-label API client (Bruno/Insomnia alternative) that dispatches requests through recker."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["redrequester"]
      }
    }
  }
}
